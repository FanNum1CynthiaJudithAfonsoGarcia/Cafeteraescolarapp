{
  "compilerOptions": {
    "target": "es2016",
    "module": "commonjs",             
    "moduleResolution": "node",
    "sourceMap": true,
    "outDir": "./dist",               
    "rootDir": "./",                 
    "strict": true,
    "esModuleInterop": true,          
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/**/*", "test.ts"], 
  "exclude": ["node_modules"]
}